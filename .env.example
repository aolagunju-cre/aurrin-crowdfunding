# Aurrin Crowdfunding — Environment Variables
# Copy this to .env.local and fill in the values

# Supabase (same project as aurrin-platform)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Platform API base (aurrin-platform deployment URL)
NEXT_PUBLIC_PLATFORM_API_URL=https://your-platform.vercel.app

# Stripe (from aurrin-platform)
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Resend (from aurrin-platform)
RESEND_API_KEY=re_...

# App URL (for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000